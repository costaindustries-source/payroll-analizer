# Copiare in .env solo per esecuzione locale fuori da Docker (uv run payroll-ingest ...).
# Con docker-compose, DATABASE_URL viene impostata automaticamente in docker-compose.yml.
DATABASE_URL=postgresql+psycopg://payroll:payroll@localhost:5432/payroll
PAYROLL_BASE_DIR=.

# POSTGRES_PASSWORD viene generata automaticamente da 'payroll setup' in .env
# (password per-macchina, non in questo file di esempio): non impostarla qui a
# mano. Se esegui il DB fuori da 'payroll setup', allinea DATABASE_URL sopra
# alla stessa password.
