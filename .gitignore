# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Virtual environments
.venv

# Runtime data (non versionati)
input/*
!input/.gitkeep
processed/*
!processed/.gitkeep
error/*
!error/.gitkeep
logs/*
!logs/.gitkeep
export/*
!export/.gitkeep
work/*
!work/.gitkeep
backups/*
!backups/.gitkeep

# Env
.env

# Cedolini reali usati come fixture di regressione (CF/importi retributivi
# reali): restano solo in locale, non vanno mai su un remote git.
docs/payroll-test/*.pdf

# Cedolini reali usati per sviluppare nuovi template (stessa ragione sopra).
docs/new-templates/

# Override locale per ambiente (es. porta host del DB pubblicata diversa da
# quella di default, per evitare collisioni su una macchina condivisa):
# v. docker-compose.override.yml.example.
docker-compose.override.yml

# Config per-macchina di 'payroll' (nome, ruolo, porta DB, retention):
# v. docs/CLI_REDESIGN_PROPOSAL.md §5. Non ancora generato da nessun comando
# (payroll setup non e' ancora implementato), ma il nome e' gia' riservato.
payroll.local.toml

